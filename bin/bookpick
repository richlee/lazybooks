#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
LIBRARY="${1:-}"

config="$(
  PYTHONPATH="$REPO_ROOT${PYTHONPATH:+:$PYTHONPATH}" python3 - <<'PY' "$LIBRARY"
import sys
from lazybooks.config import load_libraries

library_key = sys.argv[1]
libraries, default_index = load_libraries()
library = libraries[default_index]
if library_key:
    matches = [candidate for candidate in libraries if candidate.key == library_key]
    if not matches:
        print(f"Unknown library: {library_key}", file=sys.stderr)
        print("Available libraries: " + ", ".join(candidate.key for candidate in libraries), file=sys.stderr)
        raise SystemExit(2)
    library = matches[0]

print(library.manifest)
print(library.cache)
print(library.local_prefix)
print(library.remote)
print(library.name)
PY
)"

MANIFEST="$(printf '%s\n' "$config" | sed -n '1p')"
CACHE="$(printf '%s\n' "$config" | sed -n '2p')"
REMOTE_PREFIX="$(printf '%s\n' "$config" | sed -n '3p')"
REMOTE_NAME="$(printf '%s\n' "$config" | sed -n '4p')"
LIBRARY_NAME="$(printf '%s\n' "$config" | sed -n '5p')"

if [[ ! -f "$MANIFEST" ]]; then
  echo "Missing manifest: $MANIFEST"
  echo "Run bookrefresh first."
  exit 1
fi

if ! command -v fzf >/dev/null 2>&1; then
  echo "fzf is not installed."
  exit 1
fi

if ! command -v rclone >/dev/null 2>&1; then
  echo "rclone is not installed."
  exit 1
fi

selection="$(
  python3 - <<'PY' "$MANIFEST"
import json
import sys
from pathlib import Path

manifest = json.loads(Path(sys.argv[1]).read_text())

for i, book in enumerate(manifest["books"]):
    title = book.get("title", "")
    author = book.get("author", "")
    category = book.get("category", "")
    source = book.get("source", "")
    path = book.get("canonical_path", "")
    print(f"{i}\t{category}\t{title}\t{author}\t{source}\t{path}")
PY
)" || exit 1

picked="$(
  printf '%s\n' "$selection" |
    fzf \
      --delimiter=$'\t' \
      --with-nth=2,3,4 \
      --prompt="$LIBRARY_NAME> " \
      --header='Enter: fetch/open | type to filter' \
      --preview='printf "Category: {2}\nTitle: {3}\nAuthor: {4}\nSource: {5}\n\nPath:\n{6}\n"' \
      --preview-window=down,8
)"

[[ -n "$picked" ]] || exit 0

IFS=$'\t' read -r _ category title author source canonical_path <<< "$picked"

if [[ "$canonical_path" != "$REMOTE_PREFIX"* ]]; then
  echo "Unsupported path:"
  echo "$canonical_path"
  exit 1
fi

remote_path="${REMOTE_NAME}${canonical_path#"$REMOTE_PREFIX"}"

safe_title="$(
  python3 - <<'PY' "$title"
import re
import sys

name = re.sub(r"[/:]+", " - ", sys.argv[1])
name = re.sub(r"\s+", " ", name).strip()
print(name + ".pdf")
PY
)"

mkdir -p "$CACHE"
target="$CACHE/$safe_title"

echo "Fetching:"
echo "  $remote_path"
echo "-> $target"

rclone copyto "$remote_path" "$target"

open "$target"
