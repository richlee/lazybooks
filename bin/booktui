#!/usr/bin/env python3

from __future__ import annotations

import curses
import json
import os
import re
import subprocess
import sys
import textwrap
import time
from dataclasses import dataclass
from pathlib import Path

from lazybooks_config import LibraryConfig, load_libraries

PAIR_META = 2
PAIR_STATUS = 3
PAIR_ACCENT = 4
PAIR_SELECTION = 5
PAIR_AUTHOR = 6
PAIR_DIVIDER = 7
PAIR_MODAL = 8
PAIR_MODAL_BORDER = 9
HELP_MESSAGE = "Enter: fetch/open  Right/l: details  1-9: library  /: search  Tab: pane  r: refresh  q: quit"
MESSAGE_TTL_SECONDS = 3.0


@dataclass
class Book:
    title: str
    author: str
    category: str
    source: str
    canonical_path: str


def load_books(library: LibraryConfig) -> list[Book]:
    data = json.loads(library.manifest.read_text())
    return [
        Book(
            title=item.get("title", ""),
            author=item.get("author", "Unknown"),
            category=item.get("category", ""),
            source=item.get("source", ""),
            canonical_path=item.get("canonical_path", ""),
        )
        for item in data["books"]
    ]


def label_category(category: str) -> str:
    if category == "TOGAF":
        return "TOGAF Reference"
    return category.replace("-", " ").title()


def safe_name(book: Book) -> str:
    name = re.sub(r"[/:]+", " - ", book.title)
    name = re.sub(r"\s+", " ", name).strip()
    return f"{name}.pdf"


def remote_path(canonical_path: str, library: LibraryConfig) -> str:
    if not canonical_path.startswith(library.local_prefix):
        raise ValueError(f"Unsupported path: {canonical_path}")
    return library.remote + canonical_path[len(library.local_prefix) :]


def open_file(path: Path) -> None:
    if sys.platform == "darwin":
        subprocess.run(["open", str(path)], check=False)
    elif os.name == "nt":
        os.startfile(path)  # type: ignore[attr-defined]
    else:
        subprocess.run(["xdg-open", str(path)], check=False)


def fetch_book(book: Book, library: LibraryConfig) -> Path:
    library.cache.mkdir(parents=True, exist_ok=True)
    target = library.cache / safe_name(book)
    subprocess.run(["rclone", "copyto", remote_path(book.canonical_path, library), str(target)], check=True)
    return target


def cached_path(book: Book, library: LibraryConfig) -> Path:
    return library.cache / safe_name(book)


def truncate(value: str, width: int) -> str:
    if width <= 0:
        return ""
    if len(value) <= width:
        return value
    if width <= 1:
        return value[:width]
    return value[: width - 1] + "…"


def draw_text(win: curses.window, y: int, x: int, text: str, width: int, attr: int = 0) -> None:
    try:
        win.addstr(y, x, truncate(text, width), attr)
    except curses.error:
        pass


def wrap_field(label: str, value: str, width: int) -> list[str]:
    prefix = f"{label}: "
    if width <= len(prefix):
        return [truncate(prefix + value, width)]
    wrapped = textwrap.wrap(value or "-", width=width - len(prefix)) or [""]
    return [prefix + wrapped[0]] + [" " * len(prefix) + line for line in wrapped[1:]]


def muted_attr(pair: int) -> int:
    attr = curses.color_pair(pair)
    if curses.COLORS < 256:
        attr |= curses.A_DIM
    return attr


def draw_book_row(win: curses.window, y: int, x: int, book: Book, width: int, selected: bool) -> None:
    if width <= 0:
        return
    selection_attr = curses.color_pair(PAIR_SELECTION)
    author_attr = muted_attr(PAIR_AUTHOR)
    try:
        if selected:
            win.addstr(y, x, " " * width, selection_attr)
            row_text = f"{book.title} - {book.author}" if book.author and book.author != "Unknown" else book.title
            draw_text(win, y, x, row_text, width, selection_attr)
            return
        if book.author and book.author != "Unknown":
            title_part = truncate(book.title, max(0, width - len(book.author) - 3))
            draw_text(win, y, x, title_part, width)
            author_x = x + len(title_part)
            if author_x < x + width:
                draw_text(win, y, author_x, f" - {book.author}", x + width - author_x, author_attr)
        else:
            draw_text(win, y, x, book.title, width)
    except curses.error:
        pass


def status(stdscr: curses.window, message: str) -> None:
    height, width = stdscr.getmaxyx()
    stdscr.attron(curses.color_pair(PAIR_STATUS))
    stdscr.addstr(height - 1, 0, " " * (width - 1))
    draw_text(stdscr, height - 1, 0, message, width - 1, curses.color_pair(PAIR_STATUS))
    stdscr.attroff(curses.color_pair(PAIR_STATUS))
    stdscr.refresh()


def init_palette() -> None:
    curses.start_color()
    curses.use_default_colors()
    if curses.COLORS >= 256:
        curses.init_pair(PAIR_META, 245, -1)
        curses.init_pair(PAIR_STATUS, 235, 109)
        curses.init_pair(PAIR_ACCENT, 114, -1)
        curses.init_pair(PAIR_SELECTION, 253, 238)
        curses.init_pair(PAIR_AUTHOR, 248, -1)
        curses.init_pair(PAIR_DIVIDER, 240, -1)
        curses.init_pair(PAIR_MODAL, 252, 236)
        curses.init_pair(PAIR_MODAL_BORDER, 109, 236)
    else:
        curses.init_pair(PAIR_META, curses.COLOR_WHITE, -1)
        curses.init_pair(PAIR_STATUS, curses.COLOR_BLACK, curses.COLOR_CYAN)
        curses.init_pair(PAIR_ACCENT, curses.COLOR_GREEN, -1)
        curses.init_pair(PAIR_SELECTION, curses.COLOR_WHITE, curses.COLOR_BLUE)
        curses.init_pair(PAIR_AUTHOR, curses.COLOR_WHITE, -1)
        curses.init_pair(PAIR_DIVIDER, curses.COLOR_BLUE, -1)
        curses.init_pair(PAIR_MODAL, curses.COLOR_WHITE, curses.COLOR_BLACK)
        curses.init_pair(PAIR_MODAL_BORDER, curses.COLOR_CYAN, curses.COLOR_BLACK)


class App:
    def __init__(self, stdscr: curses.window, libraries: list[LibraryConfig], library_index: int) -> None:
        self.stdscr = stdscr
        self.libraries = libraries
        self.library_index = library_index
        self.books: list[Book] = []
        self.categories: list[str] = ["All"]
        self.category_index = 0
        self.category_scroll = 0
        self.book_index = 0
        self.book_scroll = 0
        self.focus = "books"
        self.query = ""
        self.message = ""
        self.message_until = 0.0
        self.load_current_library()

    @property
    def library(self) -> LibraryConfig:
        return self.libraries[self.library_index]

    def load_current_library(self) -> None:
        try:
            self.books = load_books(self.library)
            self.categories = self.build_categories()
        except Exception as exc:
            self.books = []
            self.categories = ["All"]
            self.set_message(f"Could not load {self.library.name}: {exc}", ttl=6.0)
        self.category_index = 0
        self.category_scroll = 0
        self.book_index = 0
        self.book_scroll = 0
        self.query = ""

    def build_categories(self) -> list[str]:
        cats = sorted({book.category for book in self.books}, key=lambda value: label_category(value).casefold())
        return ["All"] + cats

    def visible_books(self) -> list[Book]:
        category = self.categories[self.category_index]
        terms = [term.casefold() for term in self.query.split() if term.strip()]
        result: list[Book] = []
        for book in self.books:
            if category != "All" and book.category != category:
                continue
            haystack = " ".join([book.title, book.author, book.category, book.source]).casefold()
            if all(term in haystack for term in terms):
                result.append(book)
        return sorted(result, key=lambda book: book.title.casefold())

    def clamp_book_view(self, visible_count: int, max_rows: int) -> None:
        if visible_count == 0:
            self.book_index = 0
            self.book_scroll = 0
            return
        self.book_index = min(max(0, self.book_index), visible_count - 1)
        if max_rows <= 0:
            self.book_scroll = self.book_index
            return
        if self.book_index < self.book_scroll:
            self.book_scroll = self.book_index
        elif self.book_index >= self.book_scroll + max_rows:
            self.book_scroll = self.book_index - max_rows + 1
        max_scroll = max(0, visible_count - max_rows)
        self.book_scroll = min(max(0, self.book_scroll), max_scroll)

    def clamp_category_view(self, max_rows: int) -> None:
        if not self.categories:
            self.category_index = 0
            self.category_scroll = 0
            return
        self.category_index = min(max(0, self.category_index), len(self.categories) - 1)
        if max_rows <= 0:
            self.category_scroll = self.category_index
            return
        if self.category_index < self.category_scroll:
            self.category_scroll = self.category_index
        elif self.category_index >= self.category_scroll + max_rows:
            self.category_scroll = self.category_index - max_rows + 1
        max_scroll = max(0, len(self.categories) - max_rows)
        self.category_scroll = min(max(0, self.category_scroll), max_scroll)

    def set_message(self, message: str, ttl: float = MESSAGE_TTL_SECONDS) -> None:
        self.message = message
        self.message_until = time.monotonic() + ttl

    def status_message(self) -> str:
        if self.message and time.monotonic() < self.message_until:
            return self.message
        self.message = ""
        self.message_until = 0.0
        return HELP_MESSAGE

    def draw_library_tabs(self, width: int) -> None:
        x = 0
        draw_text(self.stdscr, 0, x, "lazybooks", width, curses.A_BOLD)
        x += 11
        for idx, library in enumerate(self.libraries[:9], start=1):
            label = f"[{idx}] {library.name}"
            attr = curses.color_pair(PAIR_SELECTION) if idx - 1 == self.library_index else muted_attr(PAIR_META)
            draw_text(self.stdscr, 0, x, label, max(0, width - x), attr)
            x += len(label) + 2
            if x >= width:
                break

    def draw(self) -> None:
        stdscr = self.stdscr
        height, width = stdscr.getmaxyx()
        left_width = max(22, min(34, width // 3))
        right_width = width - left_width - 1
        visible = self.visible_books()
        detail_height = 4

        query = f"Search: {self.query}" if self.query else "Search: "

        max_rows = max(0, height - detail_height - 5)
        max_category_rows = max(0, height - 6)
        self.clamp_book_view(len(visible), max_rows)
        self.clamp_category_view(max_category_rows)
        selected_book = visible[self.book_index] if visible else None
        detail_y = height - detail_height
        stdscr.erase()

        self.draw_library_tabs(width)
        draw_text(stdscr, 1, 0, query, width, curses.color_pair(PAIR_ACCENT))
        stdscr.attron(curses.color_pair(PAIR_DIVIDER))
        stdscr.hline(2, 0, curses.ACS_HLINE, width - 1)
        stdscr.vline(3, left_width, curses.ACS_VLINE, max(0, height - 5))
        stdscr.attroff(curses.color_pair(PAIR_DIVIDER))

        draw_text(stdscr, 3, 0, " Categories", left_width, curses.A_BOLD)
        draw_text(stdscr, 3, left_width + 2, " Books", right_width, curses.A_BOLD)

        for row, category in enumerate(self.categories[self.category_scroll : self.category_scroll + max_category_rows], start=4):
            idx = self.category_scroll + row - 4
            label = label_category(category) if category != "All" else "All"
            count = len([b for b in self.books if category == "All" or b.category == category])
            attr = curses.color_pair(PAIR_SELECTION) if self.focus == "categories" and idx == self.category_index else 0
            draw_text(stdscr, row, 1, f"{label} ({count})", left_width - 2, attr)

        start = self.book_scroll
        for row, book in enumerate(visible[start : start + max_rows], start=4):
            idx = start + row - 4
            selected = self.focus == "books" and idx == self.book_index
            draw_book_row(stdscr, row, left_width + 2, book, right_width - 2, selected)

        stdscr.attron(curses.color_pair(PAIR_DIVIDER))
        stdscr.hline(detail_y - 1, left_width + 1, curses.ACS_HLINE, max(0, right_width - 1))
        stdscr.attroff(curses.color_pair(PAIR_DIVIDER))
        if selected_book:
            book = selected_book
            cache_state = "cached" if cached_path(book, self.library).exists() else "not cached"
            category_label = label_category(book.category)
            detail_title = truncate(book.title, max(0, right_width - len(book.author) - len(category_label) - 8))
            detail_x = left_width + 2
            draw_text(stdscr, detail_y, detail_x, detail_title, right_width - 2, curses.color_pair(PAIR_ACCENT))
            detail_x += len(detail_title)
            if book.author and book.author != "Unknown":
                author_text = f" | {book.author}"
                draw_text(stdscr, detail_y, detail_x, author_text, right_width - (detail_x - left_width), muted_attr(PAIR_AUTHOR))
                detail_x += len(author_text)
            category_text = f" | {category_label}"
            draw_text(stdscr, detail_y, detail_x, category_text, right_width - (detail_x - left_width), muted_attr(PAIR_META))
            draw_text(stdscr, detail_y + 1, left_width + 2, f"Cache: {cache_state} | Source: {book.source}", right_width - 2, muted_attr(PAIR_META))
            path_x = left_width + 2
            path_width = right_width - 2
            for offset, line in enumerate(textwrap.wrap(book.canonical_path, width=max(10, path_width))[:3], start=2):
                draw_text(stdscr, detail_y + offset, path_x, line, path_width, muted_attr(PAIR_META))

        status(stdscr, self.status_message())

    def prompt_search(self) -> None:
        curses.noecho()
        curses.curs_set(1)
        self.stdscr.timeout(-1)
        height, width = self.stdscr.getmaxyx()
        value = self.query
        pristine = True
        input_width = max(1, width - 9)

        def redraw_prompt() -> None:
            self.stdscr.addstr(height - 1, 0, "Search: " + " " * input_width)
            draw_text(self.stdscr, height - 1, 8, value, input_width)
            cursor_x = min(8 + len(value), width - 1)
            self.stdscr.move(height - 1, cursor_x)
            self.stdscr.refresh()

        redraw_prompt()
        try:
            while True:
                key = self.stdscr.get_wch()
                if key in ("\n", "\r") or key == curses.KEY_ENTER:
                    self.query = "" if pristine else value.strip()
                    self.book_index = 0
                    self.book_scroll = 0
                    self.set_message("Search updated" if self.query else "Search cleared")
                    break
                if key == "\x1b":
                    self.set_message("Search unchanged")
                    break
                if key in ("\b", "\x7f") or key == curses.KEY_BACKSPACE:
                    if pristine:
                        pristine = False
                    value = value[:-1]
                    redraw_prompt()
                    continue
                if key == "\x15":
                    value = ""
                    pristine = False
                    redraw_prompt()
                    continue
                if isinstance(key, str) and key.isprintable():
                    if pristine:
                        value = ""
                        pristine = False
                    if len(value) < input_width:
                        value += key
                    redraw_prompt()
        except curses.error:
            self.set_message("Search unchanged")
        finally:
            curses.curs_set(0)
            self.stdscr.timeout(250)

    def open_selected(self) -> None:
        visible = self.visible_books()
        if not visible:
            self.set_message("No book selected")
            return
        book = visible[self.book_index]
        self.set_message(f"Fetching {book.title}...", ttl=30.0)
        self.draw()
        try:
            target = fetch_book(book, self.library)
            self.set_message(f"Opened {target.name}")
            open_file(target)
        except Exception as exc:
            self.set_message(f"Fetch failed: {exc}", ttl=6.0)

    def refresh(self) -> None:
        try:
            if not self.library.index_remote:
                raise RuntimeError(f"No index_remote configured for {self.library.name}")
            self.library.index_dir.mkdir(parents=True, exist_ok=True)
            subprocess.run(
                [
                    "rclone",
                    "copy",
                    self.library.index_remote,
                    str(self.library.index_dir),
                    "--filter",
                    "+ index.html",
                    "--filter",
                    "+ manifest.json",
                    "--filter",
                    "- *",
                ],
                check=True,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
            )
            self.books = load_books(self.library)
            self.categories = self.build_categories()
            self.category_index = min(self.category_index, len(self.categories) - 1)
            self.category_scroll = 0
            self.book_index = 0
            self.book_scroll = 0
            self.set_message("Index refreshed")
        except Exception as exc:
            self.set_message(f"Refresh failed: {exc}", ttl=6.0)

    def show_details(self, book: Book) -> None:
        self.draw()
        height, width = self.stdscr.getmaxyx()
        left_width = max(22, min(34, width // 3))
        selected_row = 4 + max(0, self.book_index - self.book_scroll)
        modal_width = min(max(46, width // 2), max(20, width - left_width - 6))
        modal_height = min(15, max(8, height - 4))
        modal_x = min(max(left_width + 3, width - modal_width - 3), max(0, width - modal_width - 1))
        modal_y = min(max(3, selected_row - 2), max(1, height - modal_height - 2))
        body_width = max(1, modal_width - 4)
        cache_state = "cached" if cached_path(book, self.library).exists() else "not cached"
        cache_file = str(cached_path(book, self.library))

        lines: list[tuple[str, int]] = [("Book details", curses.A_BOLD | curses.color_pair(PAIR_ACCENT)), ("", 0)]
        for label, value in [
            ("Title", book.title),
            ("Author", book.author),
            ("Category", label_category(book.category)),
            ("Source", book.source),
            ("Cache", cache_state),
            ("Local", cache_file),
            ("Path", book.canonical_path),
        ]:
            attr = muted_attr(PAIR_AUTHOR) if label == "Author" else muted_attr(PAIR_META)
            if label == "Title":
                attr = curses.color_pair(PAIR_ACCENT)
            lines.extend((line, attr) for line in wrap_field(label, value, body_width))

        modal_attr = curses.color_pair(PAIR_MODAL)
        border_attr = curses.color_pair(PAIR_MODAL_BORDER)
        try:
            for row in range(modal_height):
                self.stdscr.addstr(modal_y + row, modal_x, " " * modal_width, modal_attr)
            self.stdscr.hline(modal_y, modal_x + 1, curses.ACS_HLINE, modal_width - 2, border_attr)
            self.stdscr.hline(modal_y + modal_height - 1, modal_x + 1, curses.ACS_HLINE, modal_width - 2, border_attr)
            self.stdscr.vline(modal_y + 1, modal_x, curses.ACS_VLINE, modal_height - 2, border_attr)
            self.stdscr.vline(modal_y + 1, modal_x + modal_width - 1, curses.ACS_VLINE, modal_height - 2, border_attr)
            self.stdscr.addch(modal_y, modal_x, curses.ACS_ULCORNER, border_attr)
            self.stdscr.addch(modal_y, modal_x + modal_width - 1, curses.ACS_URCORNER, border_attr)
            self.stdscr.addch(modal_y + modal_height - 1, modal_x, curses.ACS_LLCORNER, border_attr)
            self.stdscr.addch(modal_y + modal_height - 1, modal_x + modal_width - 1, curses.ACS_LRCORNER, border_attr)
        except curses.error:
            pass

        for offset, (line, attr) in enumerate(lines[: modal_height - 3], start=1):
            draw_text(self.stdscr, modal_y + offset, modal_x + 2, line, body_width, attr or modal_attr)
        draw_text(self.stdscr, modal_y + modal_height - 2, modal_x + 2, "Any key to close", body_width, muted_attr(PAIR_META))
        self.stdscr.refresh()

        self.stdscr.timeout(-1)
        try:
            self.stdscr.getch()
        finally:
            self.stdscr.timeout(250)
        self.set_message("Details closed")

    def switch_library(self, library_index: int) -> None:
        if library_index < 0 or library_index >= len(self.libraries):
            return
        if library_index == self.library_index:
            return
        self.library_index = library_index
        self.load_current_library()
        self.set_message(f"Switched to {self.library.name}")

    def run(self) -> None:
        self.stdscr.timeout(250)
        while True:
            self.draw()
            key = self.stdscr.getch()
            visible = self.visible_books()
            if key == -1:
                continue
            if ord("1") <= key <= ord("9"):
                self.switch_library(key - ord("1"))
                continue
            if key in (ord("q"), 27):
                return
            if key in (ord("\t"), 9):
                self.focus = "categories" if self.focus == "books" else "books"
            elif key in (curses.KEY_UP, ord("k")):
                if self.focus == "categories":
                    self.category_index = max(0, self.category_index - 1)
                    self.book_index = 0
                    self.book_scroll = 0
                else:
                    self.book_index = max(0, self.book_index - 1)
            elif key in (curses.KEY_DOWN, ord("j")):
                if self.focus == "categories":
                    self.category_index = min(len(self.categories) - 1, self.category_index + 1)
                    self.book_index = 0
                    self.book_scroll = 0
                else:
                    self.book_index = min(max(0, len(visible) - 1), self.book_index + 1)
            elif key in (curses.KEY_PPAGE,):
                if self.focus == "categories":
                    self.category_index = max(0, self.category_index - 10)
                    self.book_index = 0
                    self.book_scroll = 0
                else:
                    self.book_index = max(0, self.book_index - 10)
            elif key in (curses.KEY_NPAGE,):
                if self.focus == "categories":
                    self.category_index = min(len(self.categories) - 1, self.category_index + 10)
                    self.book_index = 0
                    self.book_scroll = 0
                else:
                    self.book_index = min(max(0, len(visible) - 1), self.book_index + 10)
            elif key in (curses.KEY_ENTER, 10, 13):
                if self.focus == "categories":
                    self.focus = "books"
                    self.book_index = 0
                    self.book_scroll = 0
                else:
                    self.open_selected()
            elif key in (curses.KEY_RIGHT, ord("l")):
                if visible:
                    self.show_details(visible[self.book_index])
                else:
                    self.set_message("No book selected")
            elif key == ord("/"):
                self.prompt_search()
            elif key == ord("c"):
                self.query = ""
                self.book_index = 0
                self.book_scroll = 0
                self.set_message("Search cleared")
            elif key == ord("r"):
                self.refresh()


def main(stdscr: curses.window) -> None:
    curses.curs_set(0)
    init_palette()
    stdscr.keypad(True)
    libraries, library_index = load_libraries()
    App(stdscr, libraries, library_index).run()


if __name__ == "__main__":
    curses.wrapper(main)
