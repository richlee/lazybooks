#!/usr/bin/env python3

from __future__ import annotations

import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[1]))

try:
    from lazybooks.tui.textual_app import main
except ModuleNotFoundError as exc:
    if exc.name == "textual":
        print("Textual is required for lazybooks v0.2.", file=sys.stderr)
        print("Install with: python3 -m pip install -e .", file=sys.stderr)
        raise SystemExit(1)
    raise


if __name__ == "__main__":
    raise SystemExit(main())
